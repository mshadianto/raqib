# packages/backend/.env.example
# MONI SaaS Backend Configuration

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://moni:moni_dev_2026@127.0.0.1:5432/moni_saas?schema=public

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Auth (JWT) ──────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Stripe (International Payments) ────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ─── Midtrans (Indonesia Payments) ──────────────────────────
MIDTRANS_SERVER_KEY=SB-Mid-server-...
MIDTRANS_CLIENT_KEY=SB-Mid-client-...
MIDTRANS_IS_PRODUCTION=false

# ─── SendGrid (Email) ───────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@moni.kimconsulting.id
SENDGRID_FROM_NAME=MONI GRC Platform

# ─── Hermes Agent ────────────────────────────────────────────
HERMES_API_URL=http://127.0.0.1:8765
HERMES_API_KEY=hermes_...
OPENROUTER_API_KEY=sk-or-...
HERMES_DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514

# ─── Tavily (Regulatory Search) ─────────────────────────────
TAVILY_API_KEY=tvly-...

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
